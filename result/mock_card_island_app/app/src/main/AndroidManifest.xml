<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".MockApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_mock_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_mock_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.MockCard">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.MusicPlaybackService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <receiver
            android:name=".receiver.PlayerActionReceiver"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".receiver.MockCardHostReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.mockcard.ACTION_META_CHANGED" />
                <action android:name="com.example.mockcard.ACTION_PLAY_STATE_CHANGED" />
                <action android:name="com.example.mockcard.ACTION_CARD_REFRESH" />
                <action android:name="com.example.mockcard.ACTION_XTC_TOAST_SYS" />
            </intent-filter>
        </receiver>

        <provider
            android:name=".provider.MockCardWidgetProvider"
            android:authorities="com.example.mockcard.provider.text"
            android:enabled="true"
            android:exported="true">
            <meta-data
                android:name="android.card.provider"
                android:resource="@xml/mock_desktop_player_card" />
            <meta-data
                android:name="xtcCardWidget"
                android:value="true" />
        </provider>

        <provider
            android:name=".provider.MockCardDataProvider"
            android:authorities="com.example.mockcard.provider.data"
            android:enabled="true"
            android:exported="true" />

    </application>

</manifest>
