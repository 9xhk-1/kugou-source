<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/black"
    android:scrollbars="none"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:id="@+id/content_view"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="16.5dp"
            android:textColor="@color/white"
            android:gravity="center_vertical"
            android:id="@+id/user_login_title"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_marginTop="11.5dp"
            android:text="登录"
            android:includeFontPadding="false"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="16.5dp"
            android:textColor="@color/white"
            android:gravity="center_vertical"
            android:id="@+id/login_by_qr_code"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="扫码登录"
            android:includeFontPadding="false"
            android:paddingEnd="2.5dp"
            android:layout_marginEnd="20dp"
            app:layout_constraintBottom_toBottomOf="@+id/user_login_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/user_login_title"/>
        <ImageView
            android:id="@+id/iv_login_by_qr_code"
            android:paddingTop="7.5dp"
            android:paddingBottom="7.5dp"
            android:layout_width="15dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_right_arrow"
            app:layout_constraintBottom_toBottomOf="@+id/login_by_qr_code"
            app:layout_constraintStart_toEndOf="@+id/login_by_qr_code"
            app:layout_constraintTop_toTopOf="@+id/login_by_qr_code"/>
        <EditText
            android:textSize="14dp"
            android:textColor="@color/white"
            android:textColorHint="#909090"
            android:id="@+id/user_login_phone"
            android:background="@drawable/common_input_bg"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginTop="16.5dp"
            android:hint="请输入手机号码"
            android:singleLine="true"
            android:maxLength="11"
            android:numeric="integer"
            android:inputType="number"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_login_title"/>
        <EditText
            android:textSize="14dp"
            android:textColor="@color/white"
            android:textColorHint="#909090"
            android:id="@+id/user_login_verify_code"
            android:background="@drawable/common_input_bg"
            android:paddingLeft="12dp"
            android:paddingRight="62dp"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginTop="7.5dp"
            android:hint="验证码"
            android:singleLine="true"
            android:maxLength="6"
            android:numeric="integer"
            android:inputType="number"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_login_phone"/>
        <TextView
            android:textSize="12dp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/user_login_send"
            android:background="@drawable/common_button_blue_r_20dp"
            android:layout_width="50dp"
            android:layout_height="25dp"
            android:layout_marginLeft="2dp"
            android:text="发送"
            android:layout_marginEnd="2.5dp"
            app:layout_constraintBottom_toBottomOf="@+id/user_login_verify_code"
            app:layout_constraintEnd_toEndOf="@+id/user_login_verify_code"
            app:layout_constraintTop_toTopOf="@+id/user_login_verify_code"/>
        <com.kugou.uilib.widget.textview.KGUITextView
            android:textSize="14dp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/user_login_confirm"
            android:background="@drawable/common_button_blue"
            android:layout_width="100dp"
            android:layout_height="30dp"
            android:layout_marginTop="7.5dp"
            android:text="登录"
            app:kgui_press_alpha="0.7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_login_verify_code"/>
        <com.kugou.android.watch.lite.common.widget.AutoLoadingView
            android:id="@+id/user_login_loading"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.1562"/>
        <TextView
            android:textSize="11dp"
            android:textColor="#999999"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp"
            android:text="请填写可接收验证码短信\10的手机号"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_login_confirm"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
