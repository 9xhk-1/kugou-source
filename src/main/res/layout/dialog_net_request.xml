<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="16dp"
        android:textColor="@color/auto_nt"
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="消耗流量提醒"
        app:layout_constraintBottom_toTopOf="@+id/tv_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="14dp"
        android:textColor="@color/auto_nt"
        android:gravity="center"
        android:id="@+id/tv_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="当前没有连接Wi-Fi，是否用流量播放？"
        android:lineSpacingExtra="4dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_disagree"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
    <com.kugou.uilib.widget.textview.KGUITextView
        android:textSize="14sp"
        android:textColor="@color/auto_nt"
        android:gravity="center"
        android:id="@+id/tv_disagree"
        android:background="@color/nor_list_bg"
        android:layout_width="0dp"
        android:layout_height="30dp"
        android:layout_marginTop="10dp"
        android:text="否"
        android:layout_marginStart="2.5dp"
        app:kgui_corner_radius_bottom_left="20dp"
        app:kgui_corner_radius_bottom_right="4dp"
        app:kgui_corner_radius_top_left="20dp"
        app:kgui_corner_radius_top_right="4dp"
        app:kgui_press_alpha="0.6"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/tv_agree"
        app:layout_constraintTop_toBottomOf="@+id/tv_content"/>
    <com.kugou.uilib.widget.textview.KGUITextView
        android:textSize="14sp"
        android:textColor="@color/auto_nt"
        android:gravity="center"
        android:id="@+id/tv_agree"
        android:background="@color/auto_cc"
        android:layout_width="0dp"
        android:layout_height="30dp"
        android:text="是"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2.5dp"
        app:kgui_corner_radius_bottom_left="4dp"
        app:kgui_corner_radius_bottom_right="20dp"
        app:kgui_corner_radius_top_left="4dp"
        app:kgui_corner_radius_top_right="20dp"
        app:kgui_press_alpha="0.6"
        app:layout_constraintBottom_toBottomOf="@+id/tv_disagree"
        app:layout_constraintLeft_toRightOf="@+id/tv_disagree"
        app:layout_constraintRight_toRightOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
