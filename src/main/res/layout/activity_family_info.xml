<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/content_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:id="@+id/privacy_root"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/refresh_layout"
            android:background="@color/transparent"
            android:paddingLeft="7.5dp"
            android:paddingBottom="40dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:textSize="12dp"
                android:textColor="#ffffffff"
                android:gravity="center"
                android:id="@+id/content_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="内容管控规则"
                android:lineSpacingExtra="2dp"/>
            <TextView
                android:textSize="11dp"
                android:textColor="#ffffffff"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="1.功能说明"
                android:lineSpacingExtra="2dp"/>
            <TextView
                android:textSize="10dp"
                android:textColor="#ccffffff"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="家长可以在【酷狗概念版家长端】给宝贝管理歌曲啦，快用这个功能管理下宝贝的“歌单”吧"
                android:lineSpacingExtra="2dp"/>
            <TextView
                android:textSize="11dp"
                android:textColor="#ffffffff"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="2.如何操作"
                android:lineSpacingExtra="2dp"/>
            <TextView
                android:textSize="10dp"
                android:textColor="#ccffffff"
                android:gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="用微信搜索并关注微信服务号【酷狗概念版】，点击菜单栏【好听好玩】-【家长管控】进入家长端"
                android:lineSpacingExtra="2dp"/>
            <com.kugou.uilib.widget.imageview.KGUIImageView
                android:layout_gravity="center_horizontal"
                android:id="@+id/privacy_code"
                android:background="@color/white"
                android:padding="5dp"
                android:visibility="gone"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_margin="10dp"
                android:minWidth="80dp"
                android:minHeight="80dp"
                app:kgui_corner_radius="4dp"
                app:layout_constraintBottom_toTopOf="@+id/privacy_desc"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintHeight_max="120dp"
                app:layout_constraintHeight_min="80dp"
                app:layout_constraintWidth_max="120dp"
                app:layout_constraintWidth_min="80dp"/>
            <TextView
                android:textSize="10dp"
                android:textColor="#ccffffff"
                android:gravity="center"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="2dp"/>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
