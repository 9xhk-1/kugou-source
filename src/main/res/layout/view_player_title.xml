<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/song_info_container"
        android:paddingLeft="2dp"
        android:paddingRight="2dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.04">
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/iv_song_vip"
                android:visibility="gone"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/icon_vip_entry"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="1dp"/>
            <com.kugou.android.watch.lite.common.widget.MarqueeTextView
                android:textSize="14sp"
                android:textColor="@color/auto_nt"
                android:ellipsize="marquee"
                android:gravity="start"
                android:id="@+id/tv_song_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:includeFontPadding="false"
                android:marqueeRepeatLimit="marquee_forever"
                android:layout_marginStart="2dp"
                android:layout_marginEnd="2dp"/>
        </LinearLayout>
        <com.kugou.android.watch.lite.common.widget.MarqueeTextView
            android:textSize="11sp"
            android:textColor="@color/auto_st"
            android:ellipsize="marquee"
            android:gravity="center"
            android:id="@+id/tv_song_singer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:marqueeRepeatLimit="marquee_forever"/>
    </LinearLayout>
</merge>
