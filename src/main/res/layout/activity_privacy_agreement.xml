<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/privacy_agree_root"
    android:background="@color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.kugou.uilib.widget.textview.KGUITextView
            android:textSize="12.5dp"
            android:gravity="center"
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2.5dp"
            android:text="服务条款和隐私保护提示"
            app:layout_constraintTop_toTopOf="parent"/>
        <ScrollView
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="7dp"
            android:layout_marginBottom="7dp"
            android:overScrollMode="never"
            app:layout_constraintBottom_toTopOf="@+id/disagree"
            app:layout_constraintTop_toBottomOf="@+id/title">
            <com.kugou.uilib.widget.textview.KGUITextView
                android:textSize="10.5dp"
                android:id="@+id/content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""/>
        </ScrollView>
        <com.kugou.uilib.widget.textview.KGUITextView
            android:textSize="14dp"
            android:textStyle="bold"
            android:gravity="center"
            android:id="@+id/disagree"
            android:background="@drawable/common_btn_bg_grey"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginLeft="5dp"
            android:layout_marginBottom="3dp"
            android:text="不同意"
            app:kgui_corner_radius_bottom_left="40dp"
            app:kgui_corner_radius_top_left="40dp"
            app:kgui_press_alpha="0.6"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@+id/agree"/>
        <com.kugou.uilib.widget.textview.KGUITextView
            android:textSize="14dp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:id="@+id/agree"
            android:background="@drawable/common_btn_blue"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginLeft="2dp"
            android:layout_marginRight="5dp"
            android:text="同意"
            app:kgui_corner_radius_bottom_right="40dp"
            app:kgui_corner_radius_top_right="40dp"
            app:kgui_press_alpha="0.6"
            app:layout_constraintBottom_toBottomOf="@+id/disagree"
            app:layout_constraintLeft_toRightOf="@+id/disagree"
            app:layout_constraintRight_toRightOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
