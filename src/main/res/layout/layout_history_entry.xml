<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/history_entry"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="5dp">
    <TextView
        android:textSize="14dp"
        android:gravity="center_vertical"
        android:background="@drawable/common_entry_bg"
        android:paddingLeft="4dp"
        android:layout_width="match_parent"
        android:layout_height="39dp"
        android:text="历史"
        android:drawableLeft="@drawable/icon_history_entry"
        android:drawablePadding="8.5dp"
        android:paddingStart="8.5dp"
        android:layout_marginStart="2.5dp"
        android:layout_marginEnd="2.5dp"/>
    <com.kugou.uilib.widget.textview.KGUITextView
        android:textSize="11dp"
        android:textColor="#999999"
        android:gravity="center_vertical"
        android:layout_gravity="end|center_vertical"
        android:id="@+id/tv_history_count"
        android:paddingLeft="4dp"
        android:layout_width="wrap_content"
        android:layout_height="39dp"
        android:drawablePadding="10dp"
        android:layout_marginEnd="10dp"
        app:kgui_corner_radius="10dp"/>
</FrameLayout>
