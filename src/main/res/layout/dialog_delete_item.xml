<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_view"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/hook_click_layer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.7"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.4"/>
    <TextView
        android:textSize="14sp"
        android:textColor="@color/auto_nt"
        android:gravity="center"
        android:id="@+id/tv_tip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="是否删除该曲目？"
        android:layout_marginStart="2.5dp"
        android:layout_marginEnd="2.5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.15"/>
    <com.kugou.uilib.widget.textview.KGUITextView
        android:textSize="14sp"
        android:textColor="@color/auto_nt"
        android:gravity="center"
        android:id="@+id/tv_delete"
        android:background="#e5505b"
        android:layout_width="100dp"
        android:layout_height="30dp"
        android:text="删除"
        android:layout_marginStart="2.5dp"
        app:kgui_corner_radius="20dp"
        app:kgui_press_alpha="0.6"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.44"/>
    <com.kugou.uilib.widget.textview.KGUITextView
        android:textSize="14sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/tv_cancel"
        android:background="@color/nor_list_bg"
        android:layout_width="100dp"
        android:layout_height="30dp"
        android:layout_marginTop="15dp"
        android:text="取消"
        android:layout_marginStart="2dp"
        android:layout_marginEnd="2.5dp"
        app:kgui_corner_radius="20dp"
        app:kgui_press_alpha="0.6"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.74"/>
</androidx.constraintlayout.widget.ConstraintLayout>
