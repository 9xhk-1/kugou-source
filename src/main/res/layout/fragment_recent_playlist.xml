<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/content_list_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <FrameLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginTop="6dp"
            android:layout_marginRight="40dp">
            <TextView
                android:textSize="14dp"
                android:gravity="center_vertical"
                android:layout_gravity="start|center_vertical"
                android:id="@+id/content_title"
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:text="历史"
                android:includeFontPadding="false"/>
            <ImageView
                android:layout_gravity="end|center_vertical"
                android:id="@+id/content_delete"
                android:padding="4dp"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:src="@drawable/ic_search_delete"/>
        </FrameLayout>
        <com.kugou.android.watch.lite.common.widget.recyclerview.KGRecyclerView
            android:id="@+id/content_detail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="6dp"
            android:overScrollMode="never"/>
    </LinearLayout>
    <com.kugou.android.watch.lite.common.widget.PlayerBall
        android:layout_gravity="end"
        android:id="@+id/play_ball"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="2.5dp"/>
</FrameLayout>
