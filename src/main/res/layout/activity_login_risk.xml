<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/login_risk_root"
    android:background="@color/black"
    android:paddingLeft="5dp"
    android:paddingRight="5dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/login_risk_icon"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/ic_common_tip"
        android:text="登录"
        app:layout_constraintBottom_toTopOf="@+id/login_risk_content"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toStartOf="@+id/login_risk_title"
        app:layout_constraintHorizontal_chainStyle="packed"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintWidth_percent="0.1563"/>
    <TextView
        android:textSize="15.5dp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/login_risk_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="2dp"
        android:text="账号存在风险"
        app:layout_constraintBottom_toBottomOf="@+id/login_risk_icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/login_risk_icon"
        app:layout_constraintTop_toTopOf="@+id/login_risk_icon"/>
    <TextView
        android:textSize="12.5dp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/login_risk_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="请到酷狗概念版手机端解除风险后，再登录当前设备"
        android:lineSpacingExtra="3dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/login_risk_icon"
        app:layout_constraintWidth_percent="0.7594"/>
</androidx.constraintlayout.widget.ConstraintLayout>
