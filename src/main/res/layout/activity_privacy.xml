<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/privacy_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:id="@+id/iv_back"
            android:padding="5dp"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="5dp"
            android:src="@drawable/ic_common_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="14dp"
            android:gravity="center_vertical"
            android:id="@+id/content_title"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:layout_marginRight="5dp"
            android:text="隐私政策"
            android:includeFontPadding="false"
            app:layout_constraintBottom_toBottomOf="@+id/iv_back"
            app:layout_constraintStart_toEndOf="@+id/iv_back"
            app:layout_constraintTop_toTopOf="@+id/iv_back"/>
        <com.kugou.uilib.widget.imageview.KGUIImageView
            android:id="@+id/privacy_code"
            android:background="@color/white"
            android:padding="5dp"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="10dp"
            android:minWidth="80dp"
            android:minHeight="80dp"
            app:kgui_corner_radius="4dp"
            app:layout_constraintBottom_toTopOf="@+id/privacy_desc"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintHeight_max="120dp"
            app:layout_constraintHeight_min="80dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/content_title"
            app:layout_constraintWidth_max="120dp"
            app:layout_constraintWidth_min="80dp"/>
        <TextView
            android:textSize="11dp"
            android:textStyle="bold"
            android:textColor="#999999"
            android:id="@+id/privacy_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="7.5dp"
            android:layout_marginBottom="5dp"
            android:text="扫码查看"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="@+id/privacy_code"
            app:layout_constraintRight_toRightOf="@+id/privacy_code"
            app:layout_constraintTop_toBottomOf="@+id/privacy_code"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
