<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/black"
    android:scrollbars="none"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:paddingBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.kugou.uilib.widget.textview.KGUITextView
            android:textSize="14dp"
            android:gravity="center"
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="是否关闭个性化展示？"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <com.kugou.uilib.widget.textview.KGUITextView
            android:textSize="11dp"
            android:id="@+id/content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="我们可能将您的个人信息用于向您推送您感兴趣的内容，关闭后将不再为您提供个性化推荐服务。"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            app:layout_constraintStart_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title"/>
        <com.kugou.uilib.widget.textview.KGUITextView
            android:textStyle="bold"
            android:gravity="center"
            android:id="@+id/disagree"
            android:background="@drawable/common_btn_bg_grey"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginLeft="5dp"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="6dp"
            android:text="取消"
            app:kgui_corner_radius_bottom_left="40dp"
            app:kgui_corner_radius_bottom_right="4dp"
            app:kgui_corner_radius_top_left="40dp"
            app:kgui_corner_radius_top_right="4dp"
            app:kgui_press_alpha="0.6"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@+id/agree"
            app:layout_constraintTop_toBottomOf="@+id/content"/>
        <com.kugou.uilib.widget.textview.KGUITextView
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/agree"
            android:background="@drawable/common_btn_blue"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginLeft="2dp"
            android:layout_marginRight="5dp"
            android:text="确认"
            app:kgui_corner_radius_bottom_left="4dp"
            app:kgui_corner_radius_bottom_right="40dp"
            app:kgui_corner_radius_top_left="4dp"
            app:kgui_corner_radius_top_right="40dp"
            app:kgui_press_alpha="0.6"
            app:layout_constraintBottom_toBottomOf="@+id/disagree"
            app:layout_constraintLeft_toRightOf="@+id/disagree"
            app:layout_constraintRight_toRightOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
