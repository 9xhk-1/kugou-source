<?xml version="1.0" encoding="utf-8"?>
<com.kugou.uilib.widget.layout.constraintLayout.KGUIConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:id="@+id/search_song_root"
    android:background="@color/nor_list_bg"
    android:layout_width="match_parent"
    android:layout_height="49dp"
    android:layout_marginBottom="5dp"
    android:layout_marginStart="2.5dp"
    android:layout_marginEnd="2.5dp"
    app:kgui_corner_radius="9dp">
    <TextView
        android:textSize="11dp"
        android:textColor="#999999"
        android:id="@+id/tv_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1"
        android:layout_marginStart="7.5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="14dp"
        android:textColor="@color/white"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:id="@+id/song_name"
        android:layout_width="0dp"
        android:layout_height="23dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="2dp"
        android:singleLine="true"
        android:includeFontPadding="false"
        app:layout_constraintBottom_toTopOf="@+id/author_name"
        app:layout_constraintLeft_toRightOf="@+id/tv_num"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>
    <TextView
        android:textSize="11dp"
        android:textColor="@color/secondary_txt"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:id="@+id/author_name"
        android:layout_width="0dp"
        android:layout_height="16dp"
        android:layout_marginBottom="1dp"
        android:singleLine="true"
        android:includeFontPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="@+id/song_name"
        app:layout_constraintRight_toRightOf="@+id/song_name"
        app:layout_constraintTop_toBottomOf="@+id/song_name"/>
</com.kugou.uilib.widget.layout.constraintLayout.KGUIConstraintLayout>
