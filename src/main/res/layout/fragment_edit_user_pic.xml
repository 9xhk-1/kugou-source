<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textSize="14dp"
        android:gravity="center_vertical"
        android:id="@+id/content_title"
        android:layout_width="wrap_content"
        android:layout_height="25dp"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="6dp"
        android:layout_marginRight="5dp"
        android:text="修改头像"
        android:includeFontPadding="false"/>
    <com.kugou.uilib.widget.textview.KGUITextView
        android:textSize="14dp"
        android:gravity="center_vertical"
        android:id="@+id/tv_take_pic"
        android:background="@color/nor_list_bg"
        android:paddingLeft="4dp"
        android:layout_width="match_parent"
        android:layout_height="39dp"
        android:layout_marginTop="7.5dp"
        android:text="拍照"
        android:drawableLeft="@drawable/ic_take_pic"
        android:drawablePadding="8.5dp"
        android:paddingStart="8.5dp"
        android:layout_marginStart="2.5dp"
        android:layout_marginEnd="2.5dp"
        app:kgui_corner_radius="9dp"/>
    <com.kugou.uilib.widget.textview.KGUITextView
        android:textSize="14dp"
        android:gravity="center_vertical"
        android:id="@+id/tv_from_gallery"
        android:background="@color/nor_list_bg"
        android:paddingLeft="4dp"
        android:layout_width="match_parent"
        android:layout_height="39dp"
        android:layout_marginTop="7.5dp"
        android:text="相册"
        android:drawableLeft="@drawable/ic_from_gallery"
        android:drawablePadding="8.5dp"
        android:paddingStart="8.5dp"
        android:layout_marginStart="2.5dp"
        android:layout_marginEnd="2.5dp"
        app:kgui_corner_radius="9dp"/>
</LinearLayout>
