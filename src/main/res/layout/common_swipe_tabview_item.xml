<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rl_tab_view_item"
    android:layout_width="match_parent"
    android:layout_height="45dp">
    <TextView
        android:textSize="15dp"
        android:ellipsize="end"
        android:gravity="center"
        android:id="@+id/tab_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:layout_centerInParent="true"/>
    <ViewStub
        android:id="@+id/tab_title_num_hint_viewstub"
        android:layout="@layout/kg_tab_title_num_hint_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="2dp"
        android:layout_toRightOf="@+id/tab_title"
        android:layout_centerVertical="true"/>
    <ImageView
        android:id="@+id/tab_title_skin_red"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="4dp"
        android:layout_marginTop="-4dp"
        android:layout_toRightOf="@+id/tab_title"
        android:layout_alignTop="@+id/tab_title"/>
    <TextView
        android:gravity="center"
        android:id="@+id/tab_title_skin_count"
        android:padding="2dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="17dp"
        android:layout_marginLeft="6dp"
        android:layout_marginTop="-8dp"
        android:minWidth="17dp"
        android:text=""
        android:layout_toRightOf="@+id/tab_title"
        android:layout_alignTop="@+id/tab_title"/>
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:layout_toRightOf="@+id/tab_title"
        android:layout_centerVertical="true">
        <ImageView
            android:id="@+id/comm_title_skin_image"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"/>
        <TextView
            android:id="@+id/comm_title_skin_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
</RelativeLayout>
