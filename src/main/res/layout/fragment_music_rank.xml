<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never">
    <FrameLayout
        android:id="@+id/content_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/content_list_main"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textSize="14dp"
                android:gravity="center_vertical"
                android:id="@+id/content_title"
                android:layout_width="wrap_content"
                android:layout_height="25dp"
                android:layout_marginLeft="5dp"
                android:layout_marginTop="6dp"
                android:layout_marginRight="5dp"
                android:text="音乐排行榜"
                android:includeFontPadding="false"/>
            <com.google.android.material.tabs.TabLayout
                android:layout_gravity="top"
                android:id="@+id/tab_layout"
                android:background="@color/transparent"
                android:layout_width="match_parent"
                android:layout_height="25dp"
                android:layout_marginTop="3dp"
                app:tabBackground="@color/black"
                app:tabIndicatorColor="#30c2f2"
                app:tabIndicatorFullWidth="false"
                app:tabPadding="1dp"
                app:tabSelectedTextColor="@color/white"
                app:tabTextColor="#999999"/>
            <com.kugou.android.watch.lite.common.widget.SwipeViewPager
                android:id="@+id/view_pager"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"/>
        </LinearLayout>
        <com.kugou.android.watch.lite.common.widget.PlayerBall
            android:layout_gravity="end"
            android:id="@+id/play_ball"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="2.5dp"/>
    </FrameLayout>
    <include layout="@layout/common_refresh_loading"/>
</FrameLayout>
