<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/black"
    android:scrollbars="none"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never">
    <FrameLayout
        android:id="@+id/content_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_login_qr_code"
            android:paddingBottom="10dp"
            android:descendantFocusability="afterDescendants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:gravity="center_horizontal"
                android:descendantFocusability="afterDescendants"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <com.kugou.uilib.widget.imageview.KGUIImageView
                    android:id="@+id/code_img"
                    android:background="@color/auto_nt"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:kgui_corner_radius="4dp"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textSize="16dp"
                    android:textColor="@color/auto_nt"
                    android:gravity="center_horizontal"
                    android:id="@+id/tip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7.5dp"
                    app:layout_constraintLeft_toLeftOf="parent"
                    app:layout_constraintRight_toRightOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/code_img"/>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:id="@+id/invalid_container"
                    android:background="@color/auto_bgc_36"
                    android:visibility="gone"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:layout_constraintBottom_toBottomOf="@+id/code_img"
                    app:layout_constraintLeft_toLeftOf="@+id/code_img"
                    app:layout_constraintRight_toRightOf="@+id/code_img"
                    app:layout_constraintTop_toTopOf="@+id/code_img">
                    <TextView
                        android:textSize="16dp"
                        android:textColor="@color/auto_nt"
                        android:id="@+id/tv_invalidate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="二维码已失效"/>
                    <TextView
                        android:textSize="14dp"
                        android:textColor="@color/auto_login_invalide_bt_text_selector"
                        android:gravity="center"
                        android:id="@+id/invalid_refresh"
                        android:background="@drawable/auto_login_invalidate_bt_bg_selector"
                        android:layout_width="100dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="20dp"
                        android:text="刷新"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:textSize="16.5dp"
                android:textColor="@color/white"
                android:gravity="center_vertical"
                android:id="@+id/user_login_title"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="登录"
                android:includeFontPadding="false"
                android:layout_marginStart="2.5dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="16.5dp"
                android:textColor="@color/white"
                android:gravity="center_vertical"
                android:id="@+id/login_by_phone"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="手机号登录"
                android:includeFontPadding="false"
                android:layout_marginEnd="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <ImageView
                android:id="@+id/iv_login_by_phone"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/ic_right_arrow"
                android:layout_marginStart="2.5dp"
                app:layout_constraintBottom_toBottomOf="@+id/login_by_phone"
                app:layout_constraintStart_toEndOf="@+id/login_by_phone"
                app:layout_constraintTop_toTopOf="@+id/login_by_phone"/>
            <LinearLayout
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:id="@+id/info_container"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="40dp"
                app:layout_constraintTop_toTopOf="parent">
                <com.kugou.uilib.widget.imageview.KGUIImageView
                    android:id="@+id/info_img"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/auto_default_avatar"
                    app:kgui_corner_radius="50dp"/>
                <TextView
                    android:textSize="16dp"
                    android:textColor="@color/auto_nt"
                    android:id="@+id/info_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7.5dp"/>
                <TextView
                    android:textSize="11dp"
                    android:textColor="@color/white"
                    android:id="@+id/info_tip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7.5dp"/>
                <TextView
                    android:textSize="14dp"
                    android:textColor="@color/auto_button_text_selector"
                    android:gravity="center"
                    android:id="@+id/info_back"
                    android:background="@drawable/auto_settings_button_bg_selector"
                    android:layout_width="140dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="7.5dp"
                    android:text="返回扫码"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
</ScrollView>
