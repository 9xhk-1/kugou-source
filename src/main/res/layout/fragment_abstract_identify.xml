<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="10dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/root_view"
        android:background="@color/black"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">
        <View
            android:layout_gravity="center"
            android:id="@+id/identify_wave_1"
            android:background="@drawable/bg_blue_circle_frame"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:layout_constraintBottom_toBottomOf="@+id/identify_start"
            app:layout_constraintEnd_toEndOf="@+id/identify_start"
            app:layout_constraintStart_toStartOf="@+id/identify_start"
            app:layout_constraintTop_toTopOf="@+id/identify_start"/>
        <View
            android:layout_gravity="center"
            android:id="@+id/identify_wave_2"
            android:background="@drawable/bg_blue_circle_frame"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:layout_constraintBottom_toBottomOf="@+id/identify_start"
            app:layout_constraintEnd_toEndOf="@+id/identify_start"
            app:layout_constraintStart_toStartOf="@+id/identify_start"
            app:layout_constraintTop_toTopOf="@+id/identify_start"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/identify_start"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginTop="17dp"
            android:src="@drawable/ic_audio_record"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="14dp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/identify_dec"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="识别周围的音乐"
            android:includeFontPadding="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/identify_start"/>
        <TextView
            android:gravity="center"
            android:id="@+id/identify_again"
            android:background="@drawable/common_button_blue"
            android:visibility="gone"
            android:layout_width="100dp"
            android:layout_height="30dp"
            android:layout_marginTop="7.5dp"
            android:text="重新识别"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/identify_dec"/>
        <TextView
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/identify_result"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:includeFontPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/identify_again"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
