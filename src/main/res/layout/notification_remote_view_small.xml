<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/notification_content"
    android:background="@drawable/player_notification_bg"
    android:paddingBottom="2dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/notification_close"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/icon_notification_close"
        android:layout_alignParentEnd="true"/>
    <ImageView
        android:gravity="center"
        android:id="@+id/notification_btn_pre"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:layout_marginTop="3dp"
        android:src="@drawable/icon_notification_prev"
        android:layout_below="@+id/notification_song_name"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"/>
    <ImageView
        android:id="@+id/notification_btn_play"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:src="@drawable/icon_notification_play"
        android:layout_alignTop="@+id/notification_btn_pre"
        android:layout_centerHorizontal="true"/>
    <ImageView
        android:gravity="center"
        android:id="@+id/notification_btn_next"
        android:layout_width="40dp"
        android:layout_height="match_parent"
        android:src="@drawable/icon_notification_next"
        android:layout_alignTop="@+id/notification_btn_pre"
        android:layout_alignParentRight="true"
        android:layout_alignParentEnd="true"/>
    <TextView
        android:textSize="12.5dp"
        android:textColor="@color/white"
        android:ellipsize="marquee"
        android:id="@+id/notification_song_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:text="@string/noti_title"
        android:singleLine="true"
        android:layout_marginStart="5dp"
        android:layout_toStartOf="@+id/notification_close"
        android:layout_alignParentStart="true"/>
</RelativeLayout>
