<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:id="@+id/back_view"
        android:layout_width="wrap_content"
        android:layout_height="25dp">
        <ImageView
            android:layout_gravity="center_vertical"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_common_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DEBUG"
            android:includeFontPadding="false"
            app:layout_constraintBottom_toBottomOf="@+id/iv_back"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/iv_back"
            app:layout_constraintTop_toTopOf="@+id/iv_back"/>
    </LinearLayout>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:paddingLeft="3dp"
            android:paddingRight="3dp"
            android:paddingBottom="40dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="6dp">
            <TextView
                android:textSize="14dp"
                android:textColor="@color/white"
                android:gravity="center_vertical"
                android:id="@+id/version_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="20dp"
                android:text="版本号：10312"/>
            <View style="@style/debug_common_line"/>
            <TextView
                android:textSize="14dp"
                android:textColor="@color/white"
                android:gravity="center_vertical"
                android:id="@+id/git_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="20dp"
                android:text="gitVersion：dfd3432a2"/>
            <View style="@style/debug_common_line"/>
            <TextView
                android:textSize="14dp"
                android:textColor="@color/white"
                android:gravity="center_vertical"
                android:id="@+id/tv_uuid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="20dp"
                android:text="uuid：dfd3432a2"/>
            <View style="@style/debug_common_line"/>
            <TextView
                android:textSize="14dp"
                android:textColor="@color/white"
                android:gravity="center_vertical"
                android:id="@+id/tv_mid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="20dp"
                android:text="mid：dfd3432a2"/>
            <View style="@style/debug_common_line"/>
            <TextView
                android:textSize="14dp"
                android:textColor="@color/white"
                android:gravity="center_vertical"
                android:id="@+id/tv_channel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="20dp"
                android:text="channel：150"/>
            <View style="@style/debug_common_line"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="14dp"
                    android:textColor="@color/white"
                    android:gravity="center_vertical"
                    android:id="@+id/test_mode_tv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="20dp"
                    android:text="测试模式开关"/>
                <CheckBox
                    android:id="@+id/test_mode_checkbox"
                    android:layout_width="35dp"
                    android:layout_height="35dp"/>
            </LinearLayout>
            <View style="@style/debug_common_line"/>
            <Button
                android:textSize="13dp"
                android:id="@+id/debug_fire_eye_java"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="模拟火眼Java Crash"/>
            <View style="@style/debug_common_line"/>
            <Button
                android:textSize="13dp"
                android:id="@+id/debug_fire_eye_native"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="40dp"
                android:text="模拟火眼Native Crash"/>
            <View style="@style/debug_common_line"/>
            <Button
                android:textSize="13dp"
                android:id="@+id/debug_fire_eye_anr"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="模拟火眼ANR"/>
            <View style="@style/debug_common_line"/>
            <Button
                android:textSize="13dp"
                android:id="@+id/button_test_java_crash"
                android:padding="0dp"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="模拟数组越界崩溃"/>
            <View style="@style/debug_common_line"/>
            <Button
                android:textSize="13dp"
                android:id="@+id/button_del_down_and_recent"
                android:padding="0dp"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="删除下载、历史记录"/>
            <View style="@style/debug_common_line"/>
            <Button
                android:textSize="13dp"
                android:id="@+id/button_download_add"
                android:padding="0dp"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="下载页注入假记录"/>
            <View style="@style/debug_common_line"/>
            <Button
                android:textSize="13dp"
                android:id="@+id/button_recent_add"
                android:padding="0dp"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="历史页注入假记录"/>
            <View style="@style/debug_common_line"/>
            <Button
                android:textSize="13dp"
                android:id="@+id/button_test_jump_pay"
                android:padding="0dp"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="模拟跳转到支付页"/>
            <View style="@style/debug_common_line"/>
            <Button
                android:textSize="13dp"
                android:id="@+id/button_login_jump"
                android:padding="0dp"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="风控页面"/>
            <View style="@style/debug_common_line"/>
            <Button
                android:textSize="13dp"
                android:id="@+id/button_limit_jump"
                android:padding="0dp"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="健康提示"/>
            <View style="@style/debug_common_line"/>
            <Button
                android:textSize="13dp"
                android:id="@+id/button_risk_jump"
                android:padding="0dp"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="风控页面"/>
            <View style="@style/debug_common_line"/>
            <Button
                android:textSize="13dp"
                android:id="@+id/button_memory_jump"
                android:padding="0dp"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="toast 内存上报"/>
            <View style="@style/debug_common_line"/>
            <TextView
                android:textSize="14dp"
                android:textColor="@color/white"
                android:gravity="center_vertical"
                android:id="@+id/tv_health_time_limit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="20dp"
                android:text="健康提示时间改1分钟：true"/>
            <View style="@style/debug_common_line"/>
            <TextView
                android:textSize="14dp"
                android:textColor="@color/white"
                android:gravity="center_vertical"
                android:id="@+id/tv_mock_url"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="20dp"/>
            <View style="@style/debug_common_line"/>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="14dp"
                    android:textColor="@color/white"
                    android:gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minHeight="20dp"
                    android:text="自定义渠道："/>
                <EditText
                    android:textSize="14dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white_50"
                    android:id="@+id/et_custom_channel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="20dp"
                    android:text=""
                    android:hint="输入渠道号"
                    android:inputType="number"/>
            </LinearLayout>
            <View style="@style/debug_common_line"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
