<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/black"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:overScrollMode="never">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:id="@+id/main_point_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="6dp"
        android:layout_marginRight="5dp"
        android:minHeight="25dp">
        <TextView
            android:textSize="14dp"
            android:gravity="center"
            android:id="@+id/content_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="收藏"
            android:includeFontPadding="false"/>
        <ImageView
            android:id="@+id/content_fav_sync_img"
            android:layout_width="20dp"
            android:layout_height="15dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="5dp"
            android:src="@drawable/icon_common_bar_header_update"/>
    </LinearLayout>
    <com.kugou.android.watch.lite.common.widget.recyclerview.KGRecyclerView
        android:id="@+id/content_detail"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="40dp"
        android:overScrollMode="never"/>
    <com.kugou.android.watch.lite.common.widget.PlayerBall
        android:layout_gravity="end"
        android:id="@+id/play_ball"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="2.5dp"/>
</FrameLayout>
