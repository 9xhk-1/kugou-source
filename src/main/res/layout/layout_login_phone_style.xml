<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:id="@+id/content_view"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <EditText
            android:textSize="14dp"
            android:textColor="@color/white"
            android:textColorHint="#999999"
            android:id="@+id/user_login_phone"
            android:background="@drawable/common_input_bg"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginTop="10dp"
            android:hint="请输入手机号码"
            android:singleLine="true"
            android:maxLength="11"
            android:numeric="integer"
            android:inputType="number"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <EditText
            android:textSize="14dp"
            android:textColor="@color/white"
            android:textColorHint="#909090"
            android:id="@+id/user_login_verify_code"
            android:background="@drawable/common_input_bg"
            android:paddingLeft="10dp"
            android:paddingRight="62dp"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_marginTop="7.5dp"
            android:hint="验证码"
            android:singleLine="true"
            android:maxLength="6"
            android:numeric="integer"
            android:inputType="number"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_login_phone"/>
        <TextView
            android:textSize="12dp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/user_login_send"
            android:background="@drawable/common_button_blue_r_20dp"
            android:layout_width="50dp"
            android:layout_height="25dp"
            android:layout_marginTop="2.5dp"
            android:text="发送"
            android:layout_marginEnd="2.5dp"
            app:layout_constraintBottom_toBottomOf="@+id/user_login_verify_code"
            app:layout_constraintEnd_toEndOf="@+id/user_login_verify_code"
            app:layout_constraintTop_toTopOf="@+id/user_login_verify_code"
            app:layout_constraintVertical_bias="0"/>
        <com.kugou.uilib.widget.textview.KGUITextView
            android:textSize="14dp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/user_login_confirm"
            android:background="@drawable/common_button_blue"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginLeft="11dp"
            android:layout_marginTop="10.5dp"
            android:layout_marginRight="11dp"
            android:layout_marginBottom="10dp"
            android:text="登录"
            app:kgui_press_alpha="0.7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_login_verify_code"/>
        <TextView
            android:textSize="10dp"
            android:textColor="@color/c_999999"
            android:id="@+id/user_login_phone_tip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="9.5dp"
            android:layout_marginTop="4.5dp"
            android:layout_marginRight="9.5dp"
            android:text="未成年人请在监护人同意与指导下使用，可接收验证码的实名手机号注册登录"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/user_login_confirm"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
