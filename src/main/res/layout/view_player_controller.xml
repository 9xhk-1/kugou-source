<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/iv_prev"
        android:padding="7dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_player_act_prev"
        app:layout_constraintBottom_toBottomOf="@+id/iv_toggle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.06"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/iv_toggle"/>
    <ImageView
        android:id="@+id/iv_toggle"
        android:padding="14dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_player_act_play"
        app:layout_constraintBottom_toBottomOf="@+id/song_cover"
        app:layout_constraintEnd_toEndOf="@+id/song_cover"
        app:layout_constraintStart_toStartOf="@+id/song_cover"
        app:layout_constraintTop_toTopOf="@+id/song_cover"/>
    <ImageView
        android:id="@+id/iv_next"
        android:padding="7dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_player_act_next"
        app:layout_constraintBottom_toBottomOf="@+id/iv_toggle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.94"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/iv_toggle"/>
</merge>
