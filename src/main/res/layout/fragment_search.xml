<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_gravity="center"
    android:background="@color/black"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/search_bar_bg"
        android:background="@drawable/common_input_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="6dp"
        android:layout_marginRight="5dp"
        app:layout_constraintDimensionRatio="15:4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_max="50dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <EditText
        android:textSize="15.5dp"
        android:textColor="@color/white"
        android:textColorHint="@color/white_50"
        android:gravity="center_vertical"
        android:id="@+id/search_bar_edit"
        android:background="@color/transparent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:hint="搜索歌曲"
        android:singleLine="true"
        android:imeOptions="actionSearch"
        android:paddingEnd="10dp"
        app:layout_constraintBottom_toBottomOf="@+id/search_bar_bg"
        app:layout_constraintEnd_toEndOf="@+id/search_bar_bg"
        app:layout_constraintHorizontal_weight="1"
        app:layout_constraintStart_toEndOf="@+id/search_bar_button"
        app:layout_constraintTop_toTopOf="@+id/search_bar_bg"
        app:layout_constraintVertical_weight="1"/>
    <ImageView
        android:id="@+id/search_bar_button"
        android:padding="7dp"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="5dp"
        android:src="@drawable/ic_search_white"
        android:alpha="0.49"
        app:layout_constraintBottom_toBottomOf="@+id/search_bar_bg"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintStart_toEndOf="@+id/search_bar_edit"
        app:layout_constraintStart_toStartOf="@+id/search_bar_bg"
        app:layout_constraintTop_toTopOf="@+id/search_bar_bg"/>
    <ScrollView
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="5dp"
        android:layout_marginTop="5dp"
        android:layout_marginRight="5dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/search_history_title">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/search_history_container"
            android:paddingBottom="40dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
    </ScrollView>
    <TextView
        android:textSize="14dp"
        android:textColor="@color/white"
        android:id="@+id/search_history_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="17dp"
        android:layout_marginRight="10dp"
        android:text="历史搜索"
        android:includeFontPadding="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/search_bar_bg"/>
    <ImageView
        android:id="@+id/search_delete"
        android:padding="6dp"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginRight="4dp"
        android:src="@drawable/ic_search_delete"
        app:layout_constraintBottom_toBottomOf="@+id/search_history_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/search_history_title"/>
    <com.kugou.android.watch.lite.common.widget.recyclerview.KGRecyclerView
        android:id="@+id/search_list"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/search_bar_bg"/>
</androidx.constraintlayout.widget.ConstraintLayout>
